@refreshToken = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiIzODQ2ZTVhZS02NDVmLTQxNjUtOTFjYi03NTIyYThjN2M5NmQiLCJ0b2tlbklkIjoiNTk1NDA2YzQtMGNiZC00ODE1LTg2MjAtODIzYTViZGJhYjMzIiwiaWF0IjoxNzc2NzEyNjQzLCJleHAiOjE3NzkzMDQ2NDN9.nw7FSTBzdowj1gVeTXnOit09zWq9Kw7T8IK6nZlmsG4"

### ═══════════════════════════════════════════════════════════════
### PHASE 1 — AUTH
### ═══════════════════════════════════════════════════════════════

### [1.a] POST /auth/register — happy path
### Expected: 201 + data.accessToken / data.refreshToken / data.user
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "email": "smoketest+{{$timestamp}}@example.com",
  "password": "password123",
  "full_name": "Smoke Test User",
  "phone": "+84912345678",
  "level": "beginner"
}

### [1.b] POST /auth/register — VALIDATION_ERROR (password too short)
### Expected: 400 + error.code = "VALIDATION_ERROR"
POST {{baseUrl}}/auth/register
Content-Type: {{contentType}}

{
  "email": "invalid@example.com",
  "password": "123",
  "full_name": "X"
}

### [2.a] POST /auth/login — happy path
### Expected: 200 + accessToken / refreshToken / user
### → Copy accessToken và refreshToken từ response vào variables ở trên
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "smoketest+1776712818@example.com",
  "password": "password123"
}

### [2.b] POST /auth/login — INVALID_CREDENTIALS (sai password)
### Expected: 401 + error.code = "INVALID_CREDENTIALS"
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "nguyenvana@example.com",
  "password": "wrong-password"
}

### [3.a] POST /auth/refresh — happy path (rotation)
### Expected: 200 + cặp token MỚI. Refresh token cũ bị revoked.
POST {{baseUrl}}/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### [3.b] POST /auth/refresh — INVALID_REFRESH_TOKEN (token đã revoked/malformed)
### Expected: 401 + error.code = "INVALID_REFRESH_TOKEN"
POST {{baseUrl}}/auth/refresh
Content-Type: {{contentType}}

{
  "refreshToken": "eyJhbGciOiJIUzI1NiJ9.revoked-or-fake.signature"
}

### [4] POST /auth/logout — revoke refresh token hiện tại
### Expected: 200 + data = null
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "refreshToken": "{{refreshToken}}"
}

### [5] POST /auth/logout-all — revoke mọi refresh token của user
### Expected: 200 + data.revokedCount
POST {{baseUrl}}/auth/logout-all
Authorization: Bearer {{accessToken}}

### [6.a] GET /auth/me — happy path
### Expected: 200 + data.user (subset: 8 fields)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### [6.b] GET /auth/me — NO_TOKEN (thiếu header)
### Expected: 401 + error.code = "NO_TOKEN"
GET {{baseUrl}}/auth/me

### ═══════════════════════════════════════════════════════════════
### PHASE 2 — PROFILE
### ═══════════════════════════════════════════════════════════════

### [7.a] GET /profile/me — happy path
### Expected: 200 + flat object (15 fields gồm total_words_saved, days_active)
GET {{baseUrl}}/profile/me
Authorization: Bearer {{accessToken}}

### [7.b] GET /profile/me — TOKEN_EXPIRED hoặc INVALID_TOKEN
### Expected: 401 + error.code = "INVALID_TOKEN"
GET {{baseUrl}}/profile/me
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.fake.signature

### [8.a] PATCH /profile/me — update 1 field
### Expected: 200 + data.full_name cập nhật (lưu ý: KHÔNG có last_login_at ở response PATCH)
PATCH {{baseUrl}}/profile/me
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "full_name": "Nguyễn Văn B"
}

### [8.b] PATCH /profile/me — NO_FIELDS_TO_UPDATE (body rỗng)
### Expected: 400 + error.code = "NO_FIELDS_TO_UPDATE"
PATCH {{baseUrl}}/profile/me
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{}

### [8.c] PATCH /profile/me — VALIDATION_ERROR (phone sai format)
### Expected: 400 + error.code = "VALIDATION_ERROR"
PATCH {{baseUrl}}/profile/me
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "phone": "12345"
}

### [9.a] POST /profile/change-password — happy path
### Expected: 200 + message = "Password changed successfully"
### Side effect: tất cả refresh token bị revoked
POST {{baseUrl}}/profile/change-password
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "password123",
  "newPassword": "newPassword456"
}

### [9.b] POST /profile/change-password — INVALID_CURRENT_PASSWORD
### Expected: 401 + error.code = "INVALID_CURRENT_PASSWORD"
POST {{baseUrl}}/profile/change-password
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "wrong-current",
  "newPassword": "newPassword456"
}

### [9.c] POST /profile/change-password — SAME_PASSWORD
### Expected: 400 + error.code = "SAME_PASSWORD"
POST {{baseUrl}}/profile/change-password
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "currentPassword": "password123",
  "newPassword": "password123"
}

### [10.a] POST /profile/avatar — upload file (multipart/form-data)
### Expected: 201/200 + data.avatar_url (full URL)
### Đổi path file theo máy local. Field name PHẢI là "avatar".
POST {{baseUrl}}/profile/avatar
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----REST-CLIENT-BOUNDARY

------REST-CLIENT-BOUNDARY
Content-Disposition: form-data; name="avatar"; filename="test-avatar.jpg"
Content-Type: image/jpeg

< ./fixtures/test-avatar.jpg
------REST-CLIENT-BOUNDARY--

### [10.b] POST /profile/avatar — NO_FILE (missing field)
### Expected: 400 + error.code = "NO_FILE"
POST {{baseUrl}}/profile/avatar
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=----REST-CLIENT-BOUNDARY

------REST-CLIENT-BOUNDARY
Content-Disposition: form-data; name="wrong_field"

some text
------REST-CLIENT-BOUNDARY--

### [11] DELETE /profile/avatar — xóa avatar
### Expected: 200 + data = null + message = "Avatar đã xóa"
DELETE {{baseUrl}}/profile/avatar
Authorization: Bearer {{accessToken}}

### [12] GET /profile/stats — happy path
### Expected: 200 + 7 fields + last_30_days_activity array (30 items)
GET {{baseUrl}}/profile/stats
Authorization: Bearer {{accessToken}}

### ═══════════════════════════════════════════════════════════════
### PHASE 3 — DICTIONARY (FLAGSHIP)
### ═══════════════════════════════════════════════════════════════

### Variables — thay bằng id/headword có thật trong DB sau khi query /search
@entryId = replace-with-real-uuid
@tagId = replace-with-real-uuid

### [13.a] GET /dictionary/search — prefix search happy path
### Expected: 200 + items[] + meta. Response có header Cache-Control: public, max-age=3600
GET {{baseUrl}}/dictionary/search?q=org&limit=20

### [13.b] GET /dictionary/search — filter pos + cefr
### Expected: 200 + items[] đã filter
GET {{baseUrl}}/dictionary/search?q=run&pos=verb,noun&cefr=B1&limit=10

### [13.c] GET /dictionary/search — VALIDATION_ERROR (q rỗng)
### Expected: 400 + error.code = "VALIDATION_ERROR"
GET {{baseUrl}}/dictionary/search?q=

### [14] GET /dictionary/trending — top 20 lookup 7 ngày qua
### Expected: 200 + data = array (có thể rỗng nếu chưa có lookups)
### Note: Backend cache in-memory 1h. /trending không bypass cache trừ khi NODE_ENV=test
GET {{baseUrl}}/dictionary/trending

### [15] GET /dictionary/categories — list tags + entry_count
### Expected: 200 + data = array [{tag_id, name, entry_count}]. Copy 1 tag_id vào @tagId
GET {{baseUrl}}/dictionary/categories

### [16] GET /dictionary/categories/:tag_id/entries — entries theo tag
### Expected: 200 + items[] + meta. total=0 nếu tag_id không tồn tại (KHÔNG 404)
GET {{baseUrl}}/dictionary/categories/{{tagId}}/entries?page=1&limit=20

### [17.a] GET /dictionary/entries/:id — public, guest mode
### Expected: 200 + full nested data (senses, word_forms, phrasal_verbs, idioms, collocations, tags, legacy_*, word_family)
### Note: Không log lookup vì guest.
GET {{baseUrl}}/dictionary/entries/{{entryId}}

### [17.b] GET /dictionary/entries/:id — authenticated, log lookup
### Expected: 200 + full data. Side effect: INSERT vào word_lookups với source='manual_search'
GET {{baseUrl}}/dictionary/entries/{{entryId}}
Authorization: Bearer {{accessToken}}

### [17.c] GET /dictionary/entries/:id — ebook source
### Expected: 200. Side effect: word_lookups với source='ebook', ebook_id=<uuid>
GET {{baseUrl}}/dictionary/entries/{{entryId}}?source=ebook&ebook_id=aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee
Authorization: Bearer {{accessToken}}

### [17.d] GET /dictionary/entries/:id — ENTRY_NOT_FOUND
### Expected: 404 + error.code = "ENTRY_NOT_FOUND"
GET {{baseUrl}}/dictionary/entries/00000000-0000-0000-0000-000000000000

### [18.a] GET /dictionary/entries/by-headword/:headword — ebook lookup shortcut
### Expected: 200 + full data (LIMIT 1 — nếu có nhiều entries cùng headword sẽ trả 1)
GET {{baseUrl}}/dictionary/entries/by-headword/run
Authorization: Bearer {{accessToken}}

### [18.b] GET by-headword — headword có ký tự đặc biệt (URL-encode)
### Expected: 200 hoặc 404 tuỳ DB
GET {{baseUrl}}/dictionary/entries/by-headword/I%27m

### [19.a] POST /dictionary/entries/:id/bookmark — happy path với note
### Expected: 201 + data.saved=true + saved_word_id
POST {{baseUrl}}/dictionary/entries/{{entryId}}/bookmark
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "note": "Từ này hay dùng trong công việc"
}

### [19.b] POST /dictionary/entries/:id/bookmark — không có body (idempotent)
### Expected: 201 (idempotent nếu đã bookmark — UPSERT note = null)
POST {{baseUrl}}/dictionary/entries/{{entryId}}/bookmark
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{}

### [19.c] POST /dictionary/entries/:id/bookmark — NO_TOKEN
### Expected: 401 + error.code = "NO_TOKEN"
POST {{baseUrl}}/dictionary/entries/{{entryId}}/bookmark
Content-Type: {{contentType}}

{}

### [20.a] DELETE /dictionary/entries/:id/bookmark — happy path
### Expected: 200 + data.saved=false
DELETE {{baseUrl}}/dictionary/entries/{{entryId}}/bookmark
Authorization: Bearer {{accessToken}}

### [20.b] DELETE bookmark — BOOKMARK_NOT_FOUND (chưa bookmark trước)
### Expected: 404 + error.code = "BOOKMARK_NOT_FOUND"
DELETE {{baseUrl}}/dictionary/entries/{{entryId}}/bookmark
Authorization: Bearer {{accessToken}}

### [21.a] GET /dictionary/saved-words — list + stats
### Expected: 200 + stats{total_saved, saved_this_week, level_progress{A1..C2}} + items[] + meta
### ⚠ stats KHÔNG phụ thuộc filter (luôn là tổng của user)
GET {{baseUrl}}/dictionary/saved-words?page=1&limit=20
Authorization: Bearer {{accessToken}}

### [21.b] GET /dictionary/saved-words — filter mastery_level + cefr + pos
### Expected: 200. items đã filter; stats vẫn giữ tổng.
GET {{baseUrl}}/dictionary/saved-words?mastery_level=new&cefr=B1&pos=verb,noun
Authorization: Bearer {{accessToken}}

### [22.a] GET /dictionary/lookup-history — group by day
### Expected: 200 + items=[{date, items:[...]}] sorted DESC theo ngày UTC. meta.total = tổng rows (không phải groups)
GET {{baseUrl}}/dictionary/lookup-history?page=1&limit=20
Authorization: Bearer {{accessToken}}

### [22.b] GET /dictionary/lookup-history — filter source=ebook
### Expected: 200. Chỉ rows có source='ebook'.
GET {{baseUrl}}/dictionary/lookup-history?source=ebook&page=1&limit=50
Authorization: Bearer {{accessToken}}

### ═══════════════════════════════════════════════════════════════
### EDGE CASES
### ═══════════════════════════════════════════════════════════════

### [E1] GET endpoint không tồn tại — NOT_FOUND
### Expected: 404 + error.code = "NOT_FOUND"
GET {{baseUrl}}/this-endpoint-does-not-exist

### [E2] Rate limit login (sau 5 request sai trong 15 phút)
### Expected: 429 + error.code = "TOO_MANY_REQUESTS"
### Chạy block [2.b] nhiều lần liên tiếp để trigger
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "ratelimit@example.com",
  "password": "wrong"
}
