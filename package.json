{
  "name": "english-admin-websites",
  "version": "1.0.0",
  "description": "Admin Dashboard for English Learning App",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "tsx watch app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx database/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed-topics": "tsx scripts/seed-topics.mts",
    "db:reset": "tsx database/reset.ts",
    "db:fresh": "tsx database/reset.ts && tsx scripts/seed.ts",
    "db:backup": "tsx database/backup.ts",
    "db:restore": "tsx database/restore.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "bcryptjs": "^2.4.3",
    "connect-flash": "^0.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-flash": "^0.0.40",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
