<%
var typeBadge  = { lexisweep: 'badge-primary', anagram: 'badge-warning' };
var levelBadge = { beginner: 'badge-success', intermediate: 'badge-warning', advanced: 'badge-info' };
var statusBadge = { draft: 'badge-warning', published: 'badge-success', archived: 'badge-secondary' };
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0">Word Lists</h1>
    <p style="margin:4px 0 0;color:var(--text-secondary)">
      <a href="/games" style="color:var(--text-secondary)">Mini-games</a> / Word Lists
    </p>
  </div>
  <a href="/games/word-lists/create" class="btn btn-primary">+ Create Word List</a>
</div>

<!-- Filters -->
<form method="GET" action="/games/word-lists" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;margin-bottom:16px">
  <div class="form-group" style="flex:1;min-width:180px;margin:0">
    <label style="font-size:12px;display:block;margin-bottom:4px">Search</label>
    <input type="text" name="search" value="<%= filters.search %>" placeholder="Word list name...">
  </div>
  <div class="form-group" style="margin:0">
    <label style="font-size:12px;display:block;margin-bottom:4px">Game type</label>
    <select name="gameType">
      <option value="">All</option>
      <option value="lexisweep" <%= filters.gameType === 'lexisweep' ? 'selected' : '' %>>LexiSweep</option>
      <option value="anagram"   <%= filters.gameType === 'anagram'   ? 'selected' : '' %>>Anagram</option>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">Filter</button>
  <a href="/games/word-lists" class="btn btn-secondary">Clear Filters</a>
</form>

<div class="card">
  <div class="card-header">
    <h2 style="margin:0">List (<%= pagination.total %>)</h2>
  </div>
  <% if (lists.length > 0) { %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th style="text-align:center">Type</th>
          <th>Topic</th>
          <th style="text-align:center">Level</th>
          <th style="text-align:center">Words</th>
          <th style="text-align:center">Status</th>
          <th style="font-size:12px">Creator</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% lists.forEach(function(l) { %>
        <tr>
          <td style="font-weight:500"><%= l.name %></td>
          <td style="text-align:center">
            <span class="badge <%= typeBadge[l.game_type] || 'badge-secondary' %>"><%= l.game_type %></span>
          </td>
          <td style="font-size:13px;color:var(--text-secondary)"><%= l.topic || '—' %></td>
          <td style="text-align:center">
            <span class="badge <%= levelBadge[l.level] || 'badge-secondary' %>"><%= l.level %></span>
          </td>
          <td style="text-align:center"><%= l.word_count %></td>
          <td style="text-align:center">
            <span class="badge <%= statusBadge[l.status] || 'badge-secondary' %>"><%= l.status %></span>
          </td>
          <td style="font-size:12px;color:var(--text-secondary)"><%= l.creator_name || '—' %></td>
          <td>
            <div style="display:flex;gap:6px">
              <a href="/games/word-lists/<%= l.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form method="POST" action="/games/word-lists/<%= l.id %>/delete" style="margin:0"
                    onsubmit="return confirm('Delete word list \'<%= l.name %>\'?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
  <% } else { %>
  <div style="padding:60px;text-align:center;color:var(--text-secondary)">
    <div style="font-size:36px;margin-bottom:12px">📋</div>
    <p style="margin:0 0 16px">No word lists yet</p>
    <a href="/games/word-lists/create" class="btn btn-primary">+ Create your first word list</a>
  </div>
  <% } %>
</div>
