<%
var levelBadge  = { beginner: 'badge-success', intermediate: 'badge-warning', advanced: 'badge-info' };
var statusBadge = { draft: 'badge-warning', published: 'badge-success', archived: 'badge-secondary' };
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0">Semantic Sets</h1>
    <p style="margin:4px 0 0;color:var(--text-secondary)">
      <a href="/games" style="color:var(--text-secondary)">Mini-games</a> / Semantic Sets
    </p>
  </div>
  <a href="/games/semantic-sets/create" class="btn btn-primary">+ Create Semantic Set</a>
</div>

<div class="card">
  <div class="card-header">
    <h2 style="margin:0">List (<%= pagination.total %>)</h2>
  </div>
  <% if (sets.length > 0) { %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Scale Description</th>
          <th style="text-align:center">Level</th>
          <th style="text-align:center">Items</th>
          <th style="text-align:center">Status</th>
          <th style="font-size:12px">Creator</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% sets.forEach(function(s) { %>
        <tr>
          <td style="font-weight:500"><%= s.name %></td>
          <td style="font-size:12px;color:var(--text-secondary);max-width:220px">
            <span style="display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="<%= s.scale_description %>">
              <%= s.scale_description %>
            </span>
          </td>
          <td style="text-align:center">
            <span class="badge <%= levelBadge[s.level] || 'badge-secondary' %>"><%= s.level %></span>
          </td>
          <td style="text-align:center"><%= s.item_count %></td>
          <td style="text-align:center">
            <span class="badge <%= statusBadge[s.status] || 'badge-secondary' %>"><%= s.status %></span>
          </td>
          <td style="font-size:12px;color:var(--text-secondary)"><%= s.creator_name || '—' %></td>
          <td>
            <div style="display:flex;gap:6px">
              <a href="/games/semantic-sets/<%= s.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
              <form method="POST" action="/games/semantic-sets/<%= s.id %>/delete" style="margin:0"
                    onsubmit="return confirm('Delete semantic set \'<%= s.name %>\'?')">
                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
              </form>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
  <% } else { %>
  <div style="padding:60px;text-align:center;color:var(--text-secondary)">
    <div style="font-size:36px;margin-bottom:12px">🎯</div>
    <p style="margin:0 0 16px">No semantic sets yet</p>
    <a href="/games/semantic-sets/create" class="btn btn-primary">+ Create your first semantic set</a>
  </div>
  <% } %>
</div>
