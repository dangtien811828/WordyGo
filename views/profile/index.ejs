<div class="page-header">
  <h1>Personal Profile</h1>
  <p>Manage your account information</p>
</div>

<%
  const roleBadge = {
    super_admin:    'badge-danger',
    content_editor: 'badge-primary',
    moderator:      'badge-warning',
  };
  const roleLabel = {
    super_admin:    'Super Admin',
    content_editor: 'Content Editor',
    moderator:      'Moderator',
  };
%>

<div style="display:grid;grid-template-columns:300px 1fr;gap:24px;align-items:start">

  <!-- ── Cột trái: Avatar & thông tin ── -->
  <div class="card" style="padding:24px;text-align:center">

    <!-- Avatar hiển thị -->
    <div style="margin-bottom:16px">
      <% if (profileAdmin.avatar_url) { %>
        <img src="<%= profileAdmin.avatar_url %>" alt="Avatar"
             style="width:96px;height:96px;border-radius:50%;object-fit:cover;border:3px solid var(--border)">
      <% } else { %>
        <div style="width:96px;height:96px;border-radius:50%;background:var(--primary);color:white;
                    display:inline-flex;align-items:center;justify-content:center;
                    font-size:36px;font-weight:700">
          <%= profileAdmin.full_name.charAt(0).toUpperCase() %>
        </div>
      <% } %>
    </div>

    <!-- Form đổi avatar -->
    <form action="/profile/update" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="full_name" value="<%= profileAdmin.full_name %>">
      <label style="cursor:pointer">
        <span class="btn btn-sm btn-secondary">Change Avatar</span>
        <input type="file" name="image" accept="image/*" style="display:none"
               onchange="this.form.submit()">
      </label>
    </form>

    <!-- Thông tin tóm tắt -->
    <div style="margin-top:20px;text-align:left;display:flex;flex-direction:column;gap:10px">
      <div style="font-size:18px;font-weight:600;text-align:center"><%= profileAdmin.full_name %></div>
      <div style="text-align:center">
        <span class="badge <%= roleBadge[profileAdmin.role] || 'badge-primary' %>">
          <%= roleLabel[profileAdmin.role] || profileAdmin.role %>
        </span>
      </div>
      <div style="border-top:1px solid var(--border);padding-top:12px;display:flex;flex-direction:column;gap:8px">
        <div style="font-size:13px;color:var(--text-secondary)">
          <span style="font-weight:500;color:var(--text)">Email:</span>
          <%= profileAdmin.email %>
        </div>
        <div style="font-size:13px;color:var(--text-secondary)">
          <span style="font-weight:500;color:var(--text)">Joined:</span>
          <%= new Date(profileAdmin.created_at).toLocaleDateString('en-US') %>
        </div>
        <% if (profileAdmin.last_login_at) { %>
        <div style="font-size:13px;color:var(--text-secondary)">
          <span style="font-weight:500;color:var(--text)">Last Login:</span>
          <%= new Date(profileAdmin.last_login_at).toLocaleString('en-US') %>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- ── Cột phải: Forms ── -->
  <div style="display:flex;flex-direction:column;gap:20px">

    <!-- Card 1: Thông tin cá nhân -->
    <div class="card">
      <div class="card-header">
        <h2>Personal Information</h2>
      </div>
      <div style="padding:20px">
        <form action="/profile/update" method="POST" enctype="multipart/form-data">
          <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
              <label>Full Name</label>
              <input type="text" name="full_name" value="<%= profileAdmin.full_name %>" required>
            </div>
            <div class="form-group">
              <label>Email</label>
              <input type="email" value="<%= profileAdmin.email %>" readonly
                     style="background:var(--bg);color:var(--text-secondary);cursor:not-allowed">
            </div>
            <div class="form-group">
              <label>Role</label>
              <input type="text" value="<%= roleLabel[profileAdmin.role] || profileAdmin.role %>" readonly
                     style="background:var(--bg);color:var(--text-secondary);cursor:not-allowed">
            </div>
            <div>
              <button type="submit" class="btn btn-primary">Update</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Card 2: Đổi mật khẩu -->
    <div class="card">
      <div class="card-header">
        <h2>Change Password</h2>
      </div>
      <div style="padding:20px">
        <form action="/profile/password" method="POST">
          <div style="display:flex;flex-direction:column;gap:16px">
            <div class="form-group">
              <label>Old Password</label>
              <input type="password" name="old_password" required autocomplete="current-password">
            </div>
            <div class="form-group">
              <label>New Password</label>
              <input type="password" name="new_password" required autocomplete="new-password" minlength="6">
            </div>
            <div class="form-group">
              <label>Confirm New Password</label>
              <input type="password" name="confirm_password" required autocomplete="new-password" minlength="6">
            </div>
            <div>
              <button type="submit" class="btn btn-primary">Change Password</button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Vùng nguy hiểm: Xóa tài khoản -->
    <div class="card" style="border-color:#FECACA">
      <div class="card-header" style="background:#FEF2F2;border-bottom-color:#FECACA">
        <h2 style="color:var(--danger)">Danger Zone</h2>
      </div>
      <div style="padding:20px;display:flex;align-items:center;justify-content:space-between">
        <div>
          <div style="font-weight:500">Delete Account</div>
          <div style="font-size:13px;color:var(--text-secondary);margin-top:2px">
            Account will be disabled and you will be logged out
          </div>
        </div>
        <button type="button" class="btn btn-danger"
                onclick="document.getElementById('deleteDialog').showModal()">
          Delete Account
        </button>
      </div>
    </div>

  </div>
</div>

<!-- ── Dialog xác nhận xóa ── -->
<dialog id="deleteDialog" style="border:1px solid var(--border);border-radius:var(--radius-lg);
        padding:24px;max-width:440px;width:100%;box-shadow:var(--shadow-md)">
  <h3 style="margin-bottom:8px;color:var(--danger)">Confirm Account Deletion</h3>
  <p style="font-size:14px;color:var(--text-secondary);margin-bottom:16px">
    This action cannot be undone. To confirm, type:
    <br><code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:13px">DELETE <%= profileAdmin.email %></code>
  </p>
  <form action="/profile/delete" method="POST">
    <div class="form-group" style="margin-bottom:16px">
      <input type="text" name="confirm_text" autocomplete="off"
             placeholder="DELETE <%= profileAdmin.email %>" style="width:100%">
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button type="button" class="btn btn-secondary"
              onclick="document.getElementById('deleteDialog').close()">Cancel</button>
      <button type="submit" class="btn btn-danger">Confirm Delete</button>
    </div>
  </form>
</dialog>
