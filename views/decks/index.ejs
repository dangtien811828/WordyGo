<%
  const levelBadge  = { beginner:'badge-success', intermediate:'badge-warning', advanced:'badge-info' };
  const statusBadge = { draft:'badge-warning', published:'badge-success', archived:'badge-secondary' };

  // Build href for the type filter chips, preserving other filters.
  const typeChipHref = function(t) {
    const params = new URLSearchParams();
    if (t && t !== 'all') params.set('type', t);
    if (filters.search) params.set('search', filters.search);
    if (filters.level)  params.set('level',  filters.level);
    if (filters.status) params.set('status', filters.status);
    const qs = params.toString();
    return '/decks' + (qs ? '?' + qs : '');
  };
  const activeType = filters.type || 'all';
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between">
  <div>
    <h1>Flashcard Decks</h1>
    <p>Manage flashcard decks</p>
  </div>
  <a href="/decks/create" class="btn btn-primary">+ Create Deck</a>
</div>

<!-- Type filter chips -->
<div style="display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap">
  <a href="<%= typeChipHref('all') %>"
     class="btn btn-sm <%= activeType === 'all'    ? 'btn-primary' : 'btn-secondary' %>">All</a>
  <a href="<%= typeChipHref('system') %>"
     class="btn btn-sm <%= activeType === 'system' ? 'btn-primary' : 'btn-secondary' %>">System</a>
  <a href="<%= typeChipHref('user') %>"
     class="btn btn-sm <%= activeType === 'user'   ? 'btn-primary' : 'btn-secondary' %>">User</a>
</div>

<!-- Filter bar -->
<div class="card" style="padding:16px;margin-bottom:20px">
  <form method="GET" action="/decks" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
    <input type="hidden" name="type" value="<%= activeType %>">
    <div class="form-group" style="margin:0;flex:1;min-width:180px">
      <label style="font-size:12px">Search</label>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="Deck name...">
    </div>
    <div class="form-group" style="margin:0;min-width:130px">
      <label style="font-size:12px">Level</label>
      <select name="level">
        <option value="">All</option>
        <option value="beginner"     <%= filters.level === 'beginner'     ? 'selected' : '' %>>Beginner</option>
        <option value="intermediate" <%= filters.level === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
        <option value="advanced"     <%= filters.level === 'advanced'     ? 'selected' : '' %>>Advanced</option>
      </select>
    </div>
    <div class="form-group" style="margin:0;min-width:120px">
      <label style="font-size:12px">Status</label>
      <select name="status">
        <option value="">All</option>
        <option value="draft"     <%= filters.status === 'draft'     ? 'selected' : '' %>>Draft</option>
        <option value="published" <%= filters.status === 'published' ? 'selected' : '' %>>Published</option>
        <option value="archived"  <%= filters.status === 'archived'  ? 'selected' : '' %>>Archived</option>
      </select>
    </div>
    <div style="display:flex;gap:8px">
      <button type="submit" class="btn btn-primary">Filter</button>
      <a href="/decks" class="btn btn-secondary">Clear Filters</a>
    </div>
  </form>
</div>

<!-- Table -->
<div class="card">
  <div class="card-header">
    <h2>Results (<%= pagination.total %>)</h2>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Type</th>
          <th style="text-align:center">Order</th>
          <th>Level</th>
          <th style="text-align:center">Cards</th>
          <th>Status</th>
          <th>Creator</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (decks && decks.length > 0) { %>
          <% decks.forEach(function(d) { %>
            <tr>
              <td>
                <div style="font-weight:500"><%= d.title %></div>
              </td>
              <td>
                <% if (d.is_system) { %>
                  <span class="badge badge-info" style="font-size:11px">SYSTEM</span>
                  <div style="font-size:11px;color:var(--text-secondary);margin-top:2px"><%= d.deck_type %></div>
                <% } else { %>
                  <span class="badge badge-secondary" style="font-size:11px"
                        title="Created by <%= d.creator_name || 'unknown' %>">USER</span>
                <% } %>
              </td>
              <td style="text-align:center;font-size:13px">
                <% if (d.is_system) { %>
                  <%= d.sort_order %>
                <% } else { %>
                  <span style="color:var(--text-secondary)">—</span>
                <% } %>
              </td>
              <td>
                <span class="badge <%= levelBadge[d.level] || '' %>"><%= d.level %></span>
              </td>
              <td style="text-align:center;font-size:13px"><%= d.card_count %></td>
              <td>
                <span class="badge <%= statusBadge[d.status] || '' %>"><%= d.status %></span>
              </td>
              <td style="font-size:13px;color:var(--text-secondary)"><%= d.creator_name || '—' %></td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:nowrap;align-items:center">
                  <% if (d.is_system) { %>
                    <button type="button" class="btn btn-sm btn-secondary"
                            title="Move up" onclick="moveDeck('<%= d.id %>', 'up')">↑</button>
                    <button type="button" class="btn btn-sm btn-secondary"
                            title="Move down" onclick="moveDeck('<%= d.id %>', 'down')">↓</button>
                  <% } %>
                  <a href="/decks/<%= d.id %>" class="btn btn-sm btn-secondary">View</a>
                  <a href="/decks/<%= d.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
                  <button type="button" class="btn btn-sm btn-danger"
                          onclick="document.getElementById('del-<%= d.id %>').showModal()">Delete</button>
                  <dialog id="del-<%= d.id %>"
                          style="border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;max-width:400px;width:100%;box-shadow:var(--shadow-md)">
                    <h3 style="margin-bottom:8px;color:var(--danger)">Delete Deck</h3>
                    <p style="font-size:14px;color:var(--text-secondary);margin-bottom:16px">
                      Deleting this deck will remove all cards and learning progress. Type:<br>
                      <code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:13px">DELETE <%= d.title %></code>
                    </p>
                    <form action="/decks/<%= d.id %>/delete" method="POST">
                      <div class="form-group" style="margin-bottom:16px">
                        <input type="text" name="confirm_text" autocomplete="off"
                               placeholder="DELETE <%= d.title %>" style="width:100%">
                      </div>
                      <div style="display:flex;gap:8px;justify-content:flex-end">
                        <button type="button" class="btn btn-secondary"
                                onclick="document.getElementById('del-<%= d.id %>').close()">Cancel</button>
                        <button type="submit" class="btn btn-danger">Confirm Delete</button>
                      </div>
                    </form>
                  </dialog>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="8" class="text-center" style="padding:40px;color:var(--text-secondary)">
              No decks found
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
</div>

<script>
async function moveDeck(id, direction) {
  try {
    const resp = await fetch('/decks/' + id + '/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ direction: direction }),
    });
    if (resp.status === 204) {
      window.location.reload();
      return;
    }
    let msg = 'Reorder failed (HTTP ' + resp.status + ')';
    try {
      const body = await resp.json();
      if (body && body.error && body.error.message) msg = body.error.message;
    } catch (_) { /* not JSON */ }
    alert(msg);
  } catch (err) {
    alert('Reorder failed: ' + (err && err.message ? err.message : err));
  }
}
</script>
