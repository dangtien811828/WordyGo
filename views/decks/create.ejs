<div class="page-header" style="display:flex;align-items:center;justify-content:space-between">
  <div>
    <h1>Tạo Deck mới</h1>
    <p><a href="/decks" style="color:var(--text-secondary)">← Flashcard Decks</a></p>
  </div>
</div>

<form action="/decks/create" method="POST">
  <div style="display:grid;grid-template-columns:1fr 300px;gap:20px;align-items:start">

    <!-- Main -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <div class="card">
        <div class="card-header"><h2>Thông tin deck</h2></div>
        <div style="padding:20px;display:flex;flex-direction:column;gap:14px">
          <div class="form-group" style="margin:0">
            <label>Tiêu đề <span style="color:var(--danger)">*</span></label>
            <input type="text" name="title" required placeholder="Tên deck...">
          </div>
          <div class="form-group" style="margin:0">
            <label>Mô tả</label>
            <textarea name="description" rows="3" placeholder="Mô tả ngắn về deck..."></textarea>
          </div>
          <div class="form-group" style="margin:0">
            <label>Thumbnail URL</label>
            <input type="text" name="thumbnail_url" placeholder="https://...">
          </div>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div style="display:flex;flex-direction:column;gap:16px">
      <div class="card">
        <div class="card-header"><h2>Cài đặt</h2></div>
        <div style="padding:16px;display:flex;flex-direction:column;gap:14px">
          <div class="form-group" style="margin:0">
            <label>Cấp độ</label>
            <select name="level">
              <% VALID_LEVELS.forEach(function(l) { %>
                <option value="<%= l %>"><%= l %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label>Loại deck</label>
            <select name="deck_type">
              <option value="premade">Premade</option>
              <option value="system_generated">System Generated</option>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label>Sort order</label>
            <input type="number" name="sort_order" value="0" min="0" step="1">
            <p style="font-size:11px;color:var(--text-secondary);margin-top:4px">
              Lower number appears first on mobile flashcard home. Default 0.
            </p>
          </div>
          <div class="form-group" style="margin:0">
            <label>Trạng thái</label>
            <select name="status">
              <option value="draft" selected>Draft</option>
              <option value="published">Published</option>
              <option value="archived">Archived</option>
            </select>
          </div>
          <div class="form-group" style="margin:0">
            <label>Min Cards to Study</label>
            <input type="number" name="min_cards_to_study" value="5" min="1">
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h2>Tags</h2></div>
        <div style="padding:16px">
          <select name="tagIds" multiple style="width:100%;height:140px;padding:6px">
            <% tags.forEach(function(t) { %>
              <option value="<%= t.id %>"><%= t.name %></option>
            <% }); %>
          </select>
          <p style="font-size:11px;color:var(--text-secondary);margin-top:6px">Ctrl+Click để chọn nhiều</p>
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:8px">
        <button type="submit" class="btn btn-primary" style="width:100%">Tạo Deck</button>
        <a href="/decks" class="btn btn-secondary" style="width:100%;text-align:center">Hủy</a>
      </div>
    </div>

  </div>
</form>
