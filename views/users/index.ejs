<%
  const levelBadge  = { beginner: 'badge-success', intermediate: 'badge-warning', advanced: 'badge-info' };
  const statusBadge = { active: 'badge-success', inactive: 'badge-warning', banned: 'badge-danger' };
  const tierStyle   = {
    FREE:    'background:#F1F5F9;color:#475569',
    PREMIUM: 'background:#FEF3C7;color:#92400E',
    PRO:     'background:#E0E7FF;color:#3730A3',
  };
  const total = statusCounts.active + statusCounts.inactive + statusCounts.banned;
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between">
  <div>
    <h1>Users</h1>
    <p>Manage mobile app user accounts</p>
  </div>
  <a href="/users/create" class="btn btn-primary">+ Add User</a>
</div>

<!-- Stat cards -->
<div class="stats-grid" style="grid-template-columns:repeat(4,1fr)">
  <div class="stat-card">
    <div class="stat-icon">👥</div>
    <div><div class="stat-value"><%= total %></div><div class="stat-label">Total</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">✅</div>
    <div><div class="stat-value"><%= statusCounts.active %></div><div class="stat-label">Active</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">⏸️</div>
    <div><div class="stat-value"><%= statusCounts.inactive %></div><div class="stat-label">Disabled</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🚫</div>
    <div><div class="stat-value"><%= statusCounts.banned %></div><div class="stat-label">Banned</div></div>
  </div>
</div>

<!-- Filter bar -->
<div class="card" style="padding:16px;margin-bottom:20px">
  <form method="GET" action="/users" style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end">
    <div class="form-group" style="margin:0;flex:1;min-width:200px">
      <label style="font-size:12px">Search</label>
      <input type="text" name="search" value="<%= filters.search %>" placeholder="Name, email...">
    </div>
    <div class="form-group" style="margin:0;min-width:140px">
      <label style="font-size:12px">Status</label>
      <select name="status">
        <option value="">All</option>
        <option value="active"   <%= filters.status === 'active'   ? 'selected' : '' %>>Active</option>
        <option value="inactive" <%= filters.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
        <option value="banned"   <%= filters.status === 'banned'   ? 'selected' : '' %>>Banned</option>
      </select>
    </div>
    <div class="form-group" style="margin:0;min-width:140px">
      <label style="font-size:12px">Level</label>
      <select name="level">
        <option value="">All</option>
        <option value="beginner"     <%= filters.level === 'beginner'     ? 'selected' : '' %>>Beginner</option>
        <option value="intermediate" <%= filters.level === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
        <option value="advanced"     <%= filters.level === 'advanced'     ? 'selected' : '' %>>Advanced</option>
      </select>
    </div>
    <div style="display:flex;gap:8px">
      <button type="submit" class="btn btn-primary">Filter</button>
      <a href="/users" class="btn btn-secondary">Clear Filters</a>
    </div>
  </form>
</div>

<!-- Table -->
<div class="card">
  <div class="card-header">
    <h2>Results (<%= pagination.total %>)</h2>
  </div>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Level</th>
          <th>Plan</th>
          <th>Status</th>
          <th>Registered</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (users && users.length > 0) { %>
          <% users.forEach(function(u) { %>
            <tr>
              <td>
                <div class="user-cell">
                  <% if (u.avatar_url) { %>
                    <img src="<%= u.avatar_url %>" alt=""
                         style="width:32px;height:32px;border-radius:50%;object-fit:cover;flex-shrink:0">
                  <% } else { %>
                    <div class="avatar-sm"><%= u.full_name.charAt(0).toUpperCase() %></div>
                  <% } %>
                  <div>
                    <div style="font-weight:500"><%= u.full_name %></div>
                    <div style="font-size:12px;color:var(--text-secondary)"><%= u.email %></div>
                  </div>
                </div>
              </td>
              <td><span class="badge <%= levelBadge[u.level] || '' %>"><%= u.level %></span></td>
              <td><span class="badge" style="<%= tierStyle[u.subscription_tier] || tierStyle.FREE %>"><%= u.subscription_tier %></span></td>
              <td><span class="badge <%= statusBadge[u.status] || '' %>"><%= u.status %></span></td>
              <td style="font-size:13px;color:var(--text-secondary)">
                <%= new Date(u.created_at).toLocaleDateString('en-US') %>
              </td>
              <td>
                <div style="display:flex;gap:4px;flex-wrap:nowrap;align-items:center">
                  <a href="/users/<%= u.id %>" class="btn btn-sm btn-secondary">View</a>
                  <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
                  <form action="/users/<%= u.id %>/toggle-status" method="POST" style="margin:0">
                    <% if (u.status === 'banned') { %>
                      <input type="hidden" name="new_status" value="active">
                      <button class="btn btn-sm btn-secondary">Unban</button>
                    <% } else if (u.status === 'active') { %>
                      <input type="hidden" name="new_status" value="inactive">
                      <button class="btn btn-sm btn-secondary">Disable</button>
                    <% } else { %>
                      <input type="hidden" name="new_status" value="active">
                      <button class="btn btn-sm btn-secondary">Activate</button>
                    <% } %>
                  </form>
                  <% if (u.status !== 'banned') { %>
                    <form action="/users/<%= u.id %>/toggle-status" method="POST" style="margin:0"
                          onsubmit="return confirm('Ban this account? The user will not be able to log in.')">
                      <input type="hidden" name="new_status" value="banned">
                      <button class="btn btn-sm btn-danger">Ban</button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center" style="padding:40px;color:var(--text-secondary)">
              No users found
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
</div>
