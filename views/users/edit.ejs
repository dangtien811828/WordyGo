<div class="page-header">
  <h1>Sửa thông tin</h1>
  <p><a href="/users/<%= user.id %>">← Quay lại <%= user.full_name %></a></p>
</div>

<div style="max-width:560px">
  <div class="card">
    <div class="card-header"><h2>Thông tin người dùng</h2></div>
    <div style="padding:20px">
      <form action="/users/<%= user.id %>/edit" method="POST">
        <div style="display:flex;flex-direction:column;gap:16px">
          <div class="form-group">
            <label>Họ tên <span style="color:var(--danger)">*</span></label>
            <input type="text" name="full_name" value="<%= user.full_name %>" required minlength="2">
          </div>
          <div class="form-group">
            <label>Email</label>
            <input type="email" value="<%= user.email %>" readonly
                   style="background:var(--bg);color:var(--text-secondary);cursor:not-allowed">
          </div>
          <div class="form-group">
            <label>Số điện thoại</label>
            <input type="text" name="phone" value="<%= user.phone || '' %>" placeholder="0912345678">
          </div>
          <div class="form-group">
            <label>Cấp độ <span style="color:var(--danger)">*</span></label>
            <select name="level" required>
              <option value="beginner"     <%= user.level === 'beginner'     ? 'selected' : '' %>>Beginner</option>
              <option value="intermediate" <%= user.level === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
              <option value="advanced"     <%= user.level === 'advanced'     ? 'selected' : '' %>>Advanced</option>
            </select>
          </div>
          <div class="form-group">
            <label>Trạng thái <span style="color:var(--danger)">*</span></label>
            <select name="status" required>
              <option value="active"   <%= user.status === 'active'   ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= user.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="banned"   <%= user.status === 'banned'   ? 'selected' : '' %>>Banned</option>
            </select>
          </div>
          <div style="display:flex;gap:8px">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a href="/users/<%= user.id %>" class="btn btn-secondary">Hủy</a>
          </div>
        </div>
      </form>
    </div>
  </div>
</div>
