<%
  const levelBadge  = { beginner:'badge-success', intermediate:'badge-warning', advanced:'badge-info' };
  const statusBadge = { draft:'badge-warning', published:'badge-success', archived:'badge-secondary' };
  const planBadge   = { free:'badge-success', premium:'badge-warning', pro:'badge-info' };
  const genre   = Array.isArray(ebook.genre)   ? ebook.genre   : [];
  const chapters = Array.isArray(ebook.chapters) ? ebook.chapters : [];
%>

<link rel="stylesheet" href="/css/admin-ebook-tts.css">

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between">
  <div>
    <h1><%= ebook.title %></h1>
    <p><a href="/ebooks" style="color:var(--text-secondary)">← Ebook</a></p>
  </div>
  <div style="display:flex;gap:8px">
    <% if (canEdit) { %>
      <a href="/ebooks/<%= ebook.id %>/edit" class="btn btn-secondary">Sửa</a>
    <% } %>
    <% if (canDelete) { %>
      <button type="button" class="btn btn-danger"
              onclick="document.getElementById('dlg-delete').showModal()">Xóa</button>
    <% } else if (isModerator) { %>
      <form action="/ebooks/<%= ebook.id %>/delete" method="POST" style="margin:0">
        <input type="hidden" name="confirm_text" value="DELETE <%= ebook.title %>">
        <button type="submit" class="btn btn-danger"
                onclick="return confirm('Gửi yêu cầu xóa ebook này đến Super Admin?')">Yêu cầu xóa</button>
      </form>
    <% } %>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 280px;gap:20px;align-items:start;margin-bottom:20px">

  <!-- Main info -->
  <div class="card">
    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center">
      <h2>Thông tin sách</h2>
      <div style="display:flex;gap:6px">
        <span class="badge <%= levelBadge[ebook.level] || '' %>"><%= ebook.level %></span>
        <span class="badge <%= statusBadge[ebook.status] || '' %>"><%= ebook.status %></span>
        <span class="badge <%= planBadge[ebook.required_plan] || '' %>" style="font-size:11px"><%= ebook.required_plan %></span>
      </div>
    </div>
    <div style="padding:16px;display:flex;gap:16px">
      <% if (ebook.cover_url) { %>
        <img src="<%= ebook.cover_url %>" alt="Cover"
             style="width:80px;min-width:80px;height:110px;object-fit:cover;border-radius:6px;border:1px solid var(--border)">
      <% } %>
      <div style="flex:1">
        <table style="width:100%;border-collapse:collapse">
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);width:140px;font-size:13px">Tác giả</td>
            <td style="padding:8px 0"><%= ebook.author || '—' %></td>
          </tr>
          <% if (ebook.isbn) { %>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">ISBN</td>
            <td style="padding:8px 0"><%= ebook.isbn %></td>
          </tr>
          <% } %>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">Chapters</td>
            <td style="padding:8px 0"><%= ebook.total_chapters || chapters.length %></td>
          </tr>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">Tổng từ</td>
            <td style="padding:8px 0"><%= ebook.total_words ? ebook.total_words.toLocaleString() : '—' %></td>
          </tr>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">TTS Voice</td>
            <td style="padding:8px 0"><%= ebook.tts_voice || '—' %></td>
          </tr>
          <% if (ebook.epub_file_url) { %>
          <tr style="border-bottom:1px solid var(--border)">
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">File</td>
            <td style="padding:8px 0">
              <a href="<%= ebook.epub_file_url %>" target="_blank" style="color:var(--primary);font-size:13px">
                Tải xuống
              </a>
            </td>
          </tr>
          <% } %>
          <tr>
            <td style="padding:8px 0;color:var(--text-secondary);font-size:13px">Người upload</td>
            <td style="padding:8px 0;font-size:13px"><%= ebook.creator_name || '—' %></td>
          </tr>
        </table>
        <% if (ebook.description) { %>
          <p style="margin-top:12px;font-size:13px;color:var(--text-secondary);line-height:1.5"><%= ebook.description %></p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div style="display:flex;flex-direction:column;gap:16px">
    <div class="card">
      <div class="card-header"><h2>Thể loại</h2></div>
      <div style="padding:16px;display:flex;flex-wrap:wrap;gap:6px">
        <% if (genre.length > 0) { %>
          <% genre.forEach(function(g) { %>
            <span class="badge badge-primary"><%= g %></span>
          <% }); %>
        <% } else { %>
          <span style="color:var(--text-secondary);font-size:13px">Chưa có</span>
        <% } %>
      </div>
    </div>
    <div class="stats-grid" style="grid-template-columns:1fr">
      <div class="stat-card">
        <div class="stat-icon">📖</div>
        <div>
          <div class="stat-value"><%= chapters.length %></div>
          <div class="stat-label">Chapters</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Chapters list -->
<div class="card">
  <div class="card-header">
    <h2>Danh sách Chapters (<%= chapters.length %>)</h2>
  </div>
  <% if (chapters.length > 0) { %>
  <div class="table-wrapper">
    <table data-ebook-id="<%= ebook.id %>" id="chapters-table">
      <thead>
        <tr>
          <th style="width:60px">#</th>
          <th>Tiêu đề chương</th>
          <th style="text-align:center;width:90px">Số từ</th>
          <th style="text-align:center;width:240px">TTS</th>
        </tr>
      </thead>
      <tbody>
        <% chapters.forEach(function(c) {
             const ttsStatus   = c.tts_status   || 'none';
             const ttsProgress = c.tts_progress || 0;
        %>
          <tr>
            <td style="color:var(--text-secondary);font-size:13px"><%= c.chapter_index %></td>
            <td style="font-size:14px"><%= c.title || `Chapter ${c.chapter_index}` %></td>
            <td style="text-align:center;font-size:13px;color:var(--text-secondary)">
              <%= c.word_count ? c.word_count.toLocaleString() : '—' %>
            </td>
            <td style="text-align:center">
              <div class="tts-cell" data-chapter-id="<%= c.id %>">
                <% if (ttsStatus === 'ready') { %>
                  <a href="/ebooks/<%= ebook.id %>/chapters/<%= c.id %>/audio-preview" class="tts-done">
                    ✅ Audio ready
                  </a>
                <% } else if (ttsStatus === 'generating') { %>
                  <div class="tts-progress" data-chapter-id="<%= c.id %>">
                    <div class="progress-track">
                      <div class="progress-bar" style="width: <%= ttsProgress %>%"></div>
                    </div>
                    <span class="progress-text"><%= ttsProgress %>%</span>
                  </div>
                <% } else if (ttsStatus === 'failed') { %>
                  <div class="tts-failed">
                    <span class="tts-error">⚠️ Failed (<%= ttsProgress %>%)</span>
                    <button type="button" class="btn-generate-tts btn btn-secondary"
                            data-chapter-id="<%= c.id %>">Retry</button>
                  </div>
                <% } else { %>
                  <button type="button" class="btn-generate-tts btn btn-primary"
                          data-chapter-id="<%= c.id %>">Generate TTS</button>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
    <div style="padding:40px;text-align:center;color:var(--text-secondary)">
      Chưa có chapter nào
    </div>
  <% } %>
</div>

<script src="/js/admin-ebook-tts.js" defer></script>

<!-- Delete dialog (chỉ hiện với admin hoặc content_editor sở hữu sách) -->
<% if (canDelete) { %>
<dialog id="dlg-delete"
        style="border:1px solid var(--border);border-radius:var(--radius-lg);padding:24px;max-width:400px;width:100%;box-shadow:var(--shadow-md)">
  <h3 style="margin-bottom:8px;color:var(--danger)">Xóa ebook "<%= ebook.title %>"</h3>
  <p style="font-size:14px;color:var(--text-secondary);margin-bottom:16px">
    Xóa sẽ xóa toàn bộ chapters và dữ liệu liên quan. Nhập:<br>
    <code style="background:var(--bg);padding:2px 6px;border-radius:4px;font-size:13px">DELETE <%= ebook.title %></code>
  </p>
  <form action="/ebooks/<%= ebook.id %>/delete" method="POST">
    <div class="form-group" style="margin-bottom:16px">
      <input type="text" name="confirm_text" autocomplete="off"
             placeholder="DELETE <%= ebook.title %>" style="width:100%">
    </div>
    <div style="display:flex;gap:8px;justify-content:flex-end">
      <button type="button" class="btn btn-secondary"
              onclick="document.getElementById('dlg-delete').close()">Hủy</button>
      <button type="submit" class="btn btn-danger">Xác nhận xóa</button>
    </div>
  </form>
</dialog>
<% } %>
