<%
function fmtVnd(n) {
  return n != null ? Number(n).toLocaleString('vi-VN') + '₫' : '—';
}
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0;font-size:24px;font-weight:700">💳 Subscriptions</h1>
    <p style="margin:4px 0 0;color:#666;font-size:14px">Manage subscription plans, payment methods, and transactions</p>
  </div>
</div>

<!-- Stat cards -->
<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:24px">
  <div class="card" style="padding:20px">
    <div style="font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">MRR (est.)</div>
    <div style="font-size:26px;font-weight:700"><%= fmtVnd(stats.mrr) %></div>
    <div style="font-size:12px;color:#999;margin-top:4px">Monthly recurring revenue</div>
  </div>

  <div class="card" style="padding:20px">
    <div style="font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Active subscribers</div>
    <div style="font-size:26px;font-weight:700"><%= stats.totalSubscribers %></div>
    <div style="font-size:12px;color:#999;margin-top:4px">Currently active subscriptions</div>
  </div>

  <div class="card" style="padding:20px;<%= stats.pendingTransactions > 0 ? 'border-left:4px solid #e53e3e' : '' %>">
    <div style="font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Pending transactions</div>
    <div style="font-size:26px;font-weight:700;color:<%= stats.pendingTransactions > 0 ? '#e53e3e' : 'inherit' %>"><%= stats.pendingTransactions %></div>
    <div style="font-size:12px;color:#999;margin-top:4px">
      <% if (stats.pendingTransactions > 0) { %>
        <a href="/subscriptions/transactions?status=pending" style="color:#e53e3e">View now →</a>
      <% } else { %>
        No pending transactions
      <% } %>
    </div>
  </div>

  <div class="card" style="padding:20px">
    <div style="font-size:11px;font-weight:600;color:#888;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px">Churn rate (30d)</div>
    <div style="font-size:26px;font-weight:700;color:<%= stats.churnRate > 10 ? '#e53e3e' : stats.churnRate > 5 ? '#dd6b20' : 'inherit' %>"><%= stats.churnRate %>%</div>
    <div style="font-size:12px;color:#999;margin-top:4px">Cancelled in last 30 days</div>
  </div>
</div>

<!-- Quick nav cards -->
<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
  <a href="/subscriptions/plans" style="text-decoration:none;color:inherit">
    <div class="card" style="padding:28px;text-align:center;cursor:pointer">
      <div style="font-size:36px;margin-bottom:12px">📦</div>
      <div style="font-weight:600;font-size:16px;margin-bottom:6px">Subscription Plans</div>
      <div style="font-size:13px;color:#718096">Manage Free / Premium / Pro plans and features</div>
      <a href="/subscriptions/plans/new" class="btn btn-sm btn-primary" style="margin-top:16px" onclick="event.stopPropagation()">+ Create Plan</a>
    </div>
  </a>

  <a href="/subscriptions/payment-methods" style="text-decoration:none;color:inherit">
    <div class="card" style="padding:28px;text-align:center;cursor:pointer">
      <div style="font-size:36px;margin-bottom:12px">💰</div>
      <div style="font-weight:600;font-size:16px;margin-bottom:6px">Payment Methods</div>
      <div style="font-size:13px;color:#718096">Momo, ZaloPay, Bank, Visa/Mastercard...</div>
      <a href="/subscriptions/payment-methods/new" class="btn btn-sm btn-primary" style="margin-top:16px" onclick="event.stopPropagation()">+ Add Method</a>
    </div>
  </a>

  <a href="/subscriptions/transactions" style="text-decoration:none;color:inherit">
    <div class="card" style="padding:28px;text-align:center;cursor:pointer;position:relative">
      <% if (stats.pendingTransactions > 0) { %>
        <span style="position:absolute;top:14px;right:14px;background:#e53e3e;color:#fff;font-size:11px;font-weight:700;padding:2px 8px;border-radius:10px"><%= stats.pendingTransactions %></span>
      <% } %>
      <div style="font-size:36px;margin-bottom:12px">📋</div>
      <div style="font-weight:600;font-size:16px;margin-bottom:6px">Transactions</div>
      <div style="font-size:13px;color:#718096">Approve / reject payment transactions</div>
      <% if (stats.pendingTransactions > 0) { %>
        <a href="/subscriptions/transactions?status=pending" class="btn btn-sm btn-danger" style="margin-top:16px" onclick="event.stopPropagation()"><%= stats.pendingTransactions %> pending</a>
      <% } else { %>
        <a href="/subscriptions/transactions" class="btn btn-sm btn-secondary" style="margin-top:16px" onclick="event.stopPropagation()">View all</a>
      <% } %>
    </div>
  </a>
</div>
