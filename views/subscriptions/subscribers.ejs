<%
var statusBadge = {
  active: 'badge-success',
  expired: 'badge-secondary',
  cancelled: 'badge-danger',
  trial: 'badge-warning',
};
var cycleLabelMap = { monthly: 'Monthly', yearly: 'Yearly', weekly: 'Weekly' };
function fmt(n) { return (n != null && n !== '') ? Number(n).toLocaleString('en-US') + '₫' : '—'; }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('en-US') : '—'; }
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0">Subscribers — <%= plan.name %></h1>
    <p style="margin:4px 0 0;color:var(--text-secondary)">
      <a href="/subscriptions" style="color:var(--text-secondary)">Subscriptions</a> / Subscribers
    </p>
  </div>
  <a href="/subscriptions" class="btn btn-secondary">← Back</a>
</div>

<div class="card">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <h2 style="margin:0">Subscriber list (<%= pagination.total.toLocaleString() %>)</h2>
  </div>

  <% if (subscribers.length > 0) { %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Plan</th>
          <th style="text-align:center">Cycle</th>
          <th style="text-align:right">Amount Paid</th>
          <th style="text-align:center">Status</th>
          <th>Start Date</th>
          <th>End Date</th>
          <th>Joined Date</th>
        </tr>
      </thead>
      <tbody>
        <% subscribers.forEach(function(s) { %>
        <tr>
          <td>
            <div style="font-weight:500"><%= s.full_name %></div>
            <div style="font-size:12px;color:var(--text-secondary)"><%= s.email %></div>
          </td>
          <td><%= s.plan_name %></td>
          <td style="text-align:center">
            <span class="badge badge-secondary"><%= cycleLabelMap[s.billing_cycle] || s.billing_cycle %></span>
          </td>
          <td style="text-align:right;font-size:13px"><%= fmt(s.price_paid) %></td>
          <td style="text-align:center">
            <span class="badge <%= statusBadge[s.status] || 'badge-secondary' %>"><%= s.status %></span>
          </td>
          <td style="font-size:12px"><%= fmtDate(s.current_period_start) %></td>
          <td style="font-size:12px"><%= fmtDate(s.current_period_end) %></td>
          <td style="font-size:12px"><%= fmtDate(s.created_at) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
  <% } else { %>
  <div style="padding:60px;text-align:center;color:var(--text-secondary)">
    No subscribers for this plan
  </div>
  <% } %>
</div>
