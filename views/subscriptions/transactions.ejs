<%
var typeBadge = {
  new:        'badge-primary',
  renew:      'badge-success',
  upgrade:    'badge-info',
  downgrade:  'badge-warning',
  cancel:     'badge-danger',
  refund:     'badge-danger',
};
var statusBadge = {
  pending:   'badge-warning',
  completed: 'badge-success',
  failed:    'badge-danger',
  refunded:  'badge-secondary',
};
function fmt(n) { return (n != null && n !== '') ? Number(n).toLocaleString('vi-VN') + '₫' : '—'; }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—'; }
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0">Giao dịch</h1>
    <p style="margin:4px 0 0;color:var(--text-secondary)">
      <a href="/subscriptions" style="color:var(--text-secondary)">Gói đăng ký</a> / Giao dịch
    </p>
  </div>
  <a href="/subscriptions" class="btn btn-secondary">← Quay lại</a>
</div>

<div class="card">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
    <h2 style="margin:0">Tất cả giao dịch (<%= pagination.total.toLocaleString() %>)</h2>
  </div>

  <% if (transactions.length > 0) { %>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Người dùng</th>
          <th>Gói</th>
          <th style="text-align:center">Loại</th>
          <th style="text-align:right">Số tiền</th>
          <th>Phương thức</th>
          <th>Mã thanh toán</th>
          <th style="text-align:center">Trạng thái</th>
          <th>Thời gian</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(function(t) { %>
        <tr>
          <td>
            <div style="font-weight:500"><%= t.full_name %></div>
            <div style="font-size:12px;color:var(--text-secondary)"><%= t.email %></div>
          </td>
          <td style="font-size:13px"><%= t.plan_name || '—' %></td>
          <td style="text-align:center">
            <span class="badge <%= typeBadge[t.type] || 'badge-secondary' %>"><%= t.type %></span>
          </td>
          <td style="text-align:right;font-size:13px;font-weight:500"><%= fmt(t.amount) %></td>
          <td style="font-size:12px;color:var(--text-secondary)"><%= t.payment_method || '—' %></td>
          <td style="font-size:11px;color:var(--text-secondary);font-family:monospace"><%= t.payment_ref || '—' %></td>
          <td style="text-align:center">
            <span class="badge <%= statusBadge[t.status] || 'badge-secondary' %>"><%= t.status %></span>
          </td>
          <td style="font-size:12px"><%= fmtDate(t.created_at) %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../partials/pagination', { pagination }) %>
  <% } else { %>
  <div style="padding:60px;text-align:center;color:var(--text-secondary)">
    Chưa có giao dịch nào
  </div>
  <% } %>
</div>
