<%
const typeBadge = {
  ewallet:       'badge-info',
  bank:          'badge-success',
  card:          'badge-warning',
  international: 'badge-secondary',
};
const typeLabel = {
  ewallet:       'E-Wallet',
  bank:          'Bank',
  card:          'Card',
  international: 'International',
};
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <div style="font-size:13px;color:#718096;margin-bottom:4px"><a href="/subscriptions" style="color:#718096">Subscriptions</a> / Payment Methods</div>
    <h1 style="margin:0;font-size:22px;font-weight:700">Payment Methods</h1>
    <p style="margin:4px 0 0;font-size:13px;color:#718096"><%= methods.length %> payment method(s)</p>
  </div>
  <a href="/subscriptions/payment-methods/new" class="btn btn-primary">+ Add New</a>
</div>

<% if (methods.length > 0) { %>
<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px">
  <% methods.forEach(function(m) {
       const v = validations[m.id] || { is_valid: false, missing_fields: [] };
       let statusLabel, statusColor;
       if (m.is_active && v.is_valid)       { statusLabel = '✅ Active';               statusColor = '#276749'; }
       else if (m.is_active && !v.is_valid)  { statusLabel = '⚠️ Active (incomplete)'; statusColor = '#975a16'; }
       else if (!m.is_active && v.is_valid)  { statusLabel = '🔴 Inactive';             statusColor = '#718096'; }
       else                                  { statusLabel = '⚙️ Not configured';       statusColor = '#c05621'; }
  %>
  <div class="card" style="padding:0;overflow:hidden;opacity:<%= m.is_active ? 1 : .65 %>">
    <div style="padding:16px;display:flex;align-items:center;gap:14px;border-bottom:1px solid #e2e8f0">
      <% if (m.logo_url) { %>
        <img src="<%= m.logo_url %>" alt="<%= m.display_name %>"
             style="width:48px;height:48px;object-fit:contain;border-radius:8px;border:1px solid #e2e8f0;padding:4px;background:#fff;flex-shrink:0">
      <% } else { %>
        <div style="width:48px;height:48px;background:#edf2f7;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">
          <%= m.method_type === 'ewallet' ? '📱' : m.method_type === 'bank' ? '🏦' : m.method_type === 'card' ? '💳' : '🌐' %>
        </div>
      <% } %>
      <div style="flex:1;min-width:0">
        <div style="font-weight:600;font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= m.display_name %></div>
        <div style="font-size:12px;color:#718096;font-family:monospace"><%= m.code %></div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px">
        <span class="badge <%= typeBadge[m.method_type] || 'badge-secondary' %>"><%= typeLabel[m.method_type] || m.method_type %></span>
      </div>
    </div>

    <!-- Status badge -->
    <div style="padding:8px 16px;background:#f7fafc;border-bottom:1px solid #e2e8f0;display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
      <span style="font-size:12px;font-weight:600;color:<%= statusColor %>"><%= statusLabel %></span>
      <% if (!v.is_valid) { %>
        <span style="font-size:11px;color:#e53e3e;text-align:right;line-height:1.4">
          Missing: <%= v.missing_fields.join(', ') %>
        </span>
      <% } %>
    </div>

    <% if (m.description) { %>
      <div style="padding:10px 16px;font-size:13px;color:#718096;border-bottom:1px solid #e2e8f0"><%= m.description %></div>
    <% } %>

    <div style="padding:10px 16px;display:flex;align-items:center;justify-content:space-between;font-size:12px;color:#718096;border-bottom:1px solid #e2e8f0">
      <span>Fee: <%= m.fee_percent > 0 ? m.fee_percent + '%' : 'Free' %></span>
      <span>Sort: #<%= m.sort_order %></span>
    </div>

    <div style="padding:10px 12px;display:flex;gap:6px;flex-wrap:wrap">
      <a href="/subscriptions/payment-methods/<%= m.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>

      <form method="POST" action="/subscriptions/payment-methods/<%= m.id %>/toggle-active" style="margin:0">
        <button type="submit"
                class="btn btn-sm <%= m.is_active ? 'btn-secondary' : 'btn-primary' %>"
                <% if (!m.is_active && !v.is_valid) { %>
                  title="Complete required fields before activating"
                  style="opacity:.5;cursor:not-allowed"
                  onclick="return confirm('This method is not fully configured (missing: <%= v.missing_fields.join(', ') %>). Try to activate anyway?')"
                <% } %>>
          <%= m.is_active ? '⏸ Disable' : '▶ Enable' %>
        </button>
      </form>

      <form method="POST" action="/subscriptions/payment-methods/<%= m.id %>/delete" style="margin:0"
            onsubmit="return confirm('Delete payment method \'' + '<%= m.display_name %>' + '\'?')">
        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
      </form>
    </div>
  </div>
  <% }); %>
</div>
<% } else { %>
<div class="card" style="padding:60px;text-align:center;color:#718096">
  <div style="font-size:40px;margin-bottom:12px">💰</div>
  <p style="margin:0 0 16px">No payment methods yet.</p>
  <a href="/subscriptions/payment-methods/new" class="btn btn-primary">+ Add New</a>
</div>
<% } %>
