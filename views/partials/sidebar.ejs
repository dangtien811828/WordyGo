<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <span class="logo-icon">E</span>
      <span class="logo-text">English Admin</span>
    </div>
    <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
      <span class="nav-icon">📊</span>
      <span class="nav-label">Dashboard</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">
      <span class="nav-icon">👥</span>
      <span class="nav-label">Người dùng</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'dictionary' ? 'active' : '' %>">
      <span class="nav-icon">📖</span>
      <span class="nav-label">Từ điển & Bài học</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'flashcards' ? 'active' : '' %>">
      <span class="nav-icon">🃏</span>
      <span class="nav-label">Flashcard Decks</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'ebooks' ? 'active' : '' %>">
      <span class="nav-icon">📚</span>
      <span class="nav-label">Ebook</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'games' ? 'active' : '' %>">
      <span class="nav-icon">🎮</span>
      <span class="nav-label">Mini-games</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'subscriptions' ? 'active' : '' %>">
      <span class="nav-icon">💳</span>
      <span class="nav-label">Gói đăng ký</span>
    </a>
    <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'ai' ? 'active' : '' %>">
      <span class="nav-icon">🤖</span>
      <span class="nav-label">Nội dung AI</span>
    </a>

    <% if (admin && admin.role === 'super_admin') { %>
      <div class="nav-divider"></div>
      <a href="/approvals" class="nav-item <%= typeof active !== 'undefined' && active === 'approvals' ? 'active' : '' %>">
        <span class="nav-icon">📋</span>
        <span class="nav-label">
          Chờ duyệt
          <% if (pendingApprovals > 0) { %>
            <span class="badge badge-danger" style="margin-left:6px"><%= pendingApprovals %></span>
          <% } %>
        </span>
      </a>
      <a href="#" class="nav-item <%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">
        <span class="nav-icon">⚙️</span>
        <span class="nav-label">Cấu hình</span>
      </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <div class="admin-info">
      <div class="admin-avatar"><%= admin.full_name.charAt(0).toUpperCase() %></div>
      <div class="admin-meta">
        <div class="admin-name"><%= admin.full_name %></div>
        <div class="admin-role"><%= admin.role.replace('_', ' ') %></div>
      </div>
    </div>
    <form action="/auth/logout" method="POST" style="margin:0">
      <button type="submit" class="btn-logout" title="Đăng xuất">↪</button>
    </form>
  </div>
</aside>
