<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="logo">
      <span class="logo-icon">E</span>
      <span class="logo-text">English Admin</span>
    </div>
    <button class="sidebar-toggle" onclick="toggleSidebar()">☰</button>
  </div>

  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-item <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
      <span class="nav-icon">📊</span>
      <span class="nav-label">Dashboard</span>
    </a>
    <a href="/users" class="nav-item <%= typeof active !== 'undefined' && active === 'users' ? 'active' : '' %>">
      <span class="nav-icon">👥</span>
      <span class="nav-label">Users</span>
    </a>
    <a href="/dictionary" class="nav-item <%= typeof active !== 'undefined' && active === 'dictionary' ? 'active' : '' %>">
      <span class="nav-icon">📖</span>
      <span class="nav-label">Dictionary</span>
    </a>
    <%# Lessons — hidden from sidebar; route /lessons still accessible via URL %>
    <a href="/decks" class="nav-item <%= typeof active !== 'undefined' && active === 'flashcards' ? 'active' : '' %>">
      <span class="nav-icon">🃏</span>
      <span class="nav-label">Flashcard Decks</span>
    </a>
    <a href="/ebooks" class="nav-item <%= typeof active !== 'undefined' && active === 'ebooks' ? 'active' : '' %>">
      <span class="nav-icon">📚</span>
      <span class="nav-label">Ebook</span>
    </a>
    <a href="/games" class="nav-item <%= typeof active !== 'undefined' && active === 'games' ? 'active' : '' %>">
      <span class="nav-icon">🎮</span>
      <span class="nav-label">Mini-games</span>
    </a>
    <% if (admin && admin.role === 'super_admin') { %>
    <a href="/subscriptions" class="nav-item <%= typeof active !== 'undefined' && active === 'subscriptions' ? 'active' : '' %>">
      <span class="nav-icon">💳</span>
      <span class="nav-label">
        Subscriptions
        <% if (typeof pendingTransactions !== 'undefined' && pendingTransactions > 0) { %>
          <span class="badge badge-danger" style="margin-left:6px"><%= pendingTransactions %></span>
        <% } %>
      </span>
    </a>
    <% if (typeof active !== 'undefined' && active === 'subscriptions') { %>
      <a href="/subscriptions/plans" class="nav-item" style="padding-left:40px;font-size:13px">
        <span class="nav-icon" style="font-size:13px">📦</span>
        <span class="nav-label">Plans</span>
      </a>
      <a href="/subscriptions/payment-methods" class="nav-item" style="padding-left:40px;font-size:13px">
        <span class="nav-icon" style="font-size:13px">💰</span>
        <span class="nav-label">Payment Methods</span>
      </a>
      <a href="/subscriptions/transactions" class="nav-item" style="padding-left:40px;font-size:13px">
        <span class="nav-icon" style="font-size:13px">📋</span>
        <span class="nav-label">
          Transactions
          <% if (typeof pendingTransactions !== 'undefined' && pendingTransactions > 0) { %>
            <span class="badge badge-danger" style="margin-left:4px"><%= pendingTransactions %></span>
          <% } %>
        </span>
      </a>
    <% } %>
    <% } %>
    <a href="/ai-content" class="nav-item <%= typeof active !== 'undefined' && active === 'ai' ? 'active' : '' %>">
      <span class="nav-icon">🤖</span>
      <span class="nav-label">AI Content</span>
    </a>

    <% if (admin && admin.role === 'super_admin') { %>
      <div class="nav-divider"></div>
      <a href="/approvals" class="nav-item <%= typeof active !== 'undefined' && active === 'approvals' ? 'active' : '' %>">
        <span class="nav-icon">📋</span>
        <span class="nav-label">
          Pending Approvals
          <% if (pendingApprovals > 0) { %>
            <span class="badge badge-danger" style="margin-left:6px"><%= pendingApprovals %></span>
          <% } %>
        </span>
      </a>
      <a href="/settings" class="nav-item <%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">
        <span class="nav-icon">⚙️</span>
        <span class="nav-label">Settings</span>
      </a>
    <% } %>
  </nav>

  <div class="sidebar-footer">
    <a href="/profile" class="admin-info" style="text-decoration:none;color:inherit;flex:1;min-width:0">
      <% if (admin.avatar_url) { %>
        <img src="<%= admin.avatar_url %>" alt="Avatar"
             style="width:36px;height:36px;border-radius:50%;object-fit:cover;flex-shrink:0">
      <% } else { %>
        <div class="admin-avatar"><%= admin.full_name.charAt(0).toUpperCase() %></div>
      <% } %>
      <div class="admin-meta">
        <div class="admin-name"><%= admin.full_name %></div>
        <div class="admin-role"><%= admin.role.replace('_', ' ') %></div>
      </div>
    </a>
    <form action="/auth/logout" method="POST" style="margin:0">
      <button type="submit" class="btn-logout" title="Logout">↪</button>
    </form>
  </div>
</aside>
