<%
var statusBadge = { draft: 'badge-warning', active: 'badge-success', archived: 'badge-secondary' };
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('vi-VN') : '—'; }
%>

<div class="page-header" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px">
  <div>
    <h1 style="margin:0">Prompt Templates</h1>
    <p style="margin:4px 0 0;color:var(--text-secondary)">
      <a href="/ai-content" style="color:var(--text-secondary)">Nội dung AI</a> / Prompts (chỉ xem)
    </p>
  </div>
</div>

<% if (templates.length > 0) { %>
<div style="display:flex;flex-direction:column;gap:16px">
  <% templates.forEach(function(t) { %>
  <div class="card">
    <div style="padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between">
      <div style="display:flex;align-items:center;gap:10px">
        <h2 style="margin:0;font-size:16px"><%= t.name %></h2>
        <span class="badge <%= statusBadge[t.status] || 'badge-secondary' %>"><%= t.status %></span>
        <span style="font-size:11px;color:var(--text-secondary);font-family:monospace">v<%= t.version || '1' %></span>
      </div>
      <span style="font-size:12px;color:var(--text-secondary);font-family:monospace"><%= t.model || '—' %></span>
    </div>

    <div style="padding:16px 20px">
      <% if (t.description) { %>
      <p style="margin:0 0 12px;font-size:13px;color:var(--text-secondary)"><%= t.description %></p>
      <% } %>

      <!-- System prompt (collapsible) -->
      <div style="margin-bottom:12px">
        <button type="button" onclick="togglePrompt(this)" data-open="false"
                style="background:none;border:none;cursor:pointer;font-size:12px;color:var(--primary);padding:0;margin-bottom:6px">
          System Prompt ▾
        </button>
        <div class="prompt-body" style="display:none">
          <pre style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;font-size:12px;overflow-x:auto;white-space:pre-wrap;word-break:break-word;margin:0;max-height:300px;overflow-y:auto"><%= t.system_prompt || '(trống)' %></pre>
        </div>
      </div>

      <!-- Expected schema -->
      <% if (t.expected_schema) { %>
      <div>
        <button type="button" onclick="togglePrompt(this)" data-open="false"
                style="background:none;border:none;cursor:pointer;font-size:12px;color:var(--primary);padding:0;margin-bottom:6px">
          Expected Schema ▾
        </button>
        <div class="prompt-body" style="display:none">
          <pre style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;font-size:12px;overflow-x:auto;white-space:pre-wrap;word-break:break-word;margin:0;max-height:200px;overflow-y:auto"><%= JSON.stringify(t.expected_schema, null, 2) %></pre>
        </div>
      </div>
      <% } %>
    </div>
  </div>
  <% }) %>
</div>
<% } else { %>
<div class="card" style="padding:60px;text-align:center;color:var(--text-secondary)">
  <div style="font-size:36px;margin-bottom:12px">📝</div>
  <p style="margin:0">Chưa có prompt template nào</p>
</div>
<% } %>

<script>
function togglePrompt(btn) {
  var body = btn.nextElementSibling;
  var open = btn.dataset.open === 'true';
  body.style.display = open ? 'none' : '';
  btn.dataset.open = open ? 'false' : 'true';
  btn.textContent = btn.textContent.replace(open ? '▲' : '▾', open ? '▾' : '▲');
}
</script>
